{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096"
      }
    },
    {
      "name": "Next.js prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3008,
      "autoPort": true,
      "env": {
        "PORT": "3008",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      }
    }
  ]
}
